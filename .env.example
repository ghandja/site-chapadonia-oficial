# Chapadonia Site — Environment Configuration
# Copy this file to .env and fill in the values.

# Node environment (development/production)
NODE_ENV=development

# Server port
PORT=3000

# CORS origin (frontend URL for production)
CORS_ORIGIN=http://localhost:3000

# JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change_this_to_a_random_secret

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=waenbxe2
DB_NAME=chapadonia

# Admin account (seeded automatically if not exists)
ADMIN_EMAIL=ghandja1@gmail.com
ADMIN_PASSWORD=change_this_admin_password

# SMTP Email Configuration (for sending Recovery Keys and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_aplicativo
SMTP_FROM="Chapadonia OT" <seu_email@gmail.com>

